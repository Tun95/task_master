{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@auth/*": ["./src/auth/*"],
      "@common/*": ["./src/utils/common/*"],
      "@config/*": ["./config/*"],
      "@prisma-local/*": ["./src/utils/prisma/*"], // Changed
      "@email/*": ["./src/utils/email/*"]
    }
  },
  "include": ["src/**/*.ts", "config/**/*.ts"],
  "exclude": ["node_modules", "test", "dist", "**/*.spec.ts"]
}
