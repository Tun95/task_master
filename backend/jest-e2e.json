{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@config/(.*)$": "<rootDir>/config/$1",
    "^@auth/(.*)$": "<rootDir>/src/auth/$1",
    "^@common/(.*)$": "<rootDir>/src/utils/common/$1",
    "^@email/(.*)$": "<rootDir>/src/utils/email/$1"
  },
  "testTimeout": 30000
}
